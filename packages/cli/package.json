{
  "name": "@akabeko/music-metadata-editor-cli",
  "description": "Command-line interface for @akabeko/music-metadata-editor.",
  "version": "1.0.0",
  "author": "akabeko (http://akabeko.me/)",
  "license": "MIT",
  "keywords": [
    "music",
    "metadata",
    "audio",
    "tag",
    "tags",
    "editor",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akabekobeko/npm-music-metadata-editor.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/akabekobeko/npm-music-metadata-editor/issues"
  },
  "homepage": "https://github.com/akabekobeko/npm-music-metadata-editor/tree/main/packages/cli#readme",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "mme": "./dist/bin/mme.js"
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsx scripts/postBuildShebang.ts",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fixtures:mp3": "tsx scripts/fixtures/mp3.ts"
  },
  "dependencies": {
    "@akabeko/music-metadata-editor": "workspace:^",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
